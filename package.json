{
  "name": "homeenter",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev:api": "npm run dev --workspace @homeenter/api",
    "dev:web": "npm run dev --workspace @homeenter/web",
    "package:tizen": "npm run package:tizen --workspace @homeenter/web",
    "package:webos": "npm run package:webos --workspace @homeenter/web",
    "typecheck": "npm run typecheck --workspaces"
  }
}
